# Supabase — copie este arquivo para .env e preencha com seus dados
# Acesse: https://supabase.com → seu projeto → Settings → API

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Google Forms Integration - API Token (Pesquisa de Clima)
# Gere um token seguro: https://generate-random.org/ (copie 64 caracteres)
# Use no Zapier: Authorization: Bearer [TOKEN_AQUI]
VITE_CLIMATE_API_TOKEN=seu_token_seguro_minimo_32_caracteres_aqui
